# -- Required ---
# Copy this file to .env and fill in real values. Never commit .env to git.

POSTGRES_PASSWORD=<yourpassword>

# -- LLM backend (ollama | groq) 
LLM_BACKEND=ollama
JQL_LOCAL_MODEL=qwen2.5:3b-instruct-q4_K_M

# -- Groq (only needed when LLM_BACKEND=groq)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# -- Jira (optional)
JIRA_URL=
JIRA_USER=
JIRA_TOKEN=
MAX_JIRA_RESULTS=500
